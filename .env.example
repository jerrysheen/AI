AI_SHARED_DATA_DIR=.ai-data
AI_CHROME_PROFILE_DIR=.chrome-sider-profile
AI_CHROME_DEBUG_PORT=9222
AI_CHROME_PATH=
AI_CHROME_STARTUP_DELAY_MS=4000
AI_YTDLP_COMMAND=python3 -m yt_dlp
AI_FFMPEG_LOCATION=.ai-data\tools\ffmpeg
AI_FFMPEG_COMMAND=ffmpeg
AI_FFPROBE_COMMAND=ffprobe
AI_WHISPER_CLI_COMMAND=whisper-cli
AI_AUTO_TRANSLATE_DEFAULT_MODEL=base
AI_AUTO_TRANSLATE_DEFAULT_LANGUAGE=auto
AI_AUTO_TRANSLATE_THREADS=4
AI_AUTO_TRANSLATE_RUNS_DIR=.ai-data/auto-translate/runs
AI_AUTO_TRANSLATE_MODELS_DIR=.ai-data/cache/whisper/models
AI_AUTO_TRANSLATE_WORKER_HOST=0.0.0.0
AI_AUTO_TRANSLATE_WORKER_PORT=8768
AI_AUTO_TRANSLATE_WORKER_TOKEN=
AI_AUTO_TRANSLATE_WORKER_MAX_UPLOAD_MB=2048
AI_AUTO_TRANSLATE_REMOTE_BASE_URL=
AI_AUTO_TRANSLATE_WORKER_JOBS_DIR=.ai-data/auto-translate/remote-jobs
AI_AUTO_TRANSLATE_REMOTE_CLIENT_RUNS_DIR=.ai-data/auto-translate/remote-client-runs
AI_AUTO_TRANSLATE_WORKER_BACKEND=cpu
AI_AUTO_TRANSLATE_GPU_PYTHON_COMMAND=python
AI_AUTO_TRANSLATE_GPU_DEVICE=cuda
AI_AUTO_TRANSLATE_GPU_COMPUTE_TYPE=float16
AI_AUTO_TRANSLATE_GPU_BEAM_SIZE=5
AI_AUTO_TRANSLATE_GPU_DEBUG=0
AI_AUTO_TRANSLATE_GPU_MODELS_DIR=.ai-data/cache/faster-whisper
AI_WHISPER_PYTHON=python
AI_REVIEW_ENGINE_HOST=127.0.0.1
AI_REVIEW_ENGINE_PORT=8776
AI_REVIEW_ENGINE_DATA_DIR=data/review-engine
AI_KNOWLEDGE_BASE_HOST=127.0.0.1
AI_KNOWLEDGE_BASE_PORT=8777
AI_KNOWLEDGE_BASE_DATA_DIR=data/knowledge-base
AI_KNOWLEDGE_BASE_AUTO_EXTRACT=true
AI_KNOWLEDGE_BASE_OPENAI_API_KEY=
AI_KNOWLEDGE_BASE_OPENAI_BASE_URL=
AI_KNOWLEDGE_BASE_OPENAI_LLM_MODEL=
AI_KNOWLEDGE_BASE_EMBED_PROVIDER=huggingface
AI_KNOWLEDGE_BASE_HF_EMBED_MODEL=BAAI/bge-small-zh-v1.5

# 音频优化选项
# 音频采样率：16000 (默认, 高质量), 8000 (语音优化, 体积小)
AI_AUDIO_SAMPLE_RATE=16000
# 音频编码：pcm_s16le (16-bit, 默认), pcm_alaw (8-bit), pcm_mulaw (8-bit)
AI_AUDIO_CODEC=pcm_s16le
# 是否默认使用 8kHz (true/false) - 大幅减少文件大小，适合语音内容
AI_AUDIO_USE_8KHZ=false
