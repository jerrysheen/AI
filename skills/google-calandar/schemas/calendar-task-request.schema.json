{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Google Calendar And Tasks Skill Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "daily_brief",
        "list_events",
        "create_event",
        "update_event",
        "delete_event",
        "list_tasklists",
        "list_tasks",
        "create_task",
        "update_task",
        "complete_task",
        "delete_task"
      ]
    },
    "days": {
      "type": "integer",
      "minimum": 1
    },
    "date": {
      "type": "string",
      "description": "UTC date in YYYY-MM-DD. Optional override for daily_brief; omit it for today's requests so the script uses the current UTC day."
    },
    "start": {
      "type": "string",
      "description": "ISO datetime range start. For UTC day boundaries, use a Z suffix, for example 2026-04-02T00:00:00Z"
    },
    "end": {
      "type": "string",
      "description": "ISO datetime range end. For UTC day boundaries, use a Z suffix, for example 2026-04-02T23:59:59Z"
    },
    "calendarId": {
      "type": "string"
    },
    "eventId": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "tasklistId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "due": {
      "type": "string",
      "description": "Prefer date-only YYYY-MM-DD unless the user explicitly gives a time"
    },
    "dueStart": {
      "type": "string",
      "description": "Task due-date range start, usually YYYY-MM-DD"
    },
    "dueEnd": {
      "type": "string",
      "description": "Task due-date range end, usually YYYY-MM-DD"
    },
    "includeCompleted": {
      "type": [
        "boolean",
        "string"
      ],
      "description": "Whether completed tasks should be included in list_tasks"
    },
    "includeHidden": {
      "type": [
        "boolean",
        "string"
      ],
      "description": "Whether hidden tasks should be included in list_tasks"
    },
    "showNotes": {
      "type": [
        "boolean",
        "string"
      ],
      "description": "Whether task notes/details should be requested when listing tasks"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "const": "daily_brief"
          }
        }
      },
      "then": {}
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "list_events"
          }
        }
      },
      "then": {
        "allOf": [
          {
            "not": {
              "required": [
                "days",
                "start"
              ]
            }
          },
          {
            "not": {
              "required": [
                "days",
                "end"
              ]
            }
          },
          {
            "if": {
              "anyOf": [
                {
                  "required": [
                    "start"
                  ]
                },
                {
                  "required": [
                    "end"
                  ]
                }
              ]
            },
            "then": {
              "required": [
                "start",
                "end"
              ]
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "create_event"
          }
        }
      },
      "then": {
        "required": [
          "title",
          "start",
          "end"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "list_tasks"
          }
        }
      },
      "then": {
        "if": {
          "anyOf": [
            {
              "required": [
                "dueStart"
              ]
            },
            {
              "required": [
                "dueEnd"
              ]
            }
          ]
        },
        "then": {
          "required": [
            "dueStart",
            "dueEnd"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "update_event"
          }
        }
      },
      "then": {
        "required": [
          "eventId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "delete_event"
          }
        }
      },
      "then": {
        "required": [
          "eventId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "create_task"
          }
        }
      },
      "then": {
        "required": [
          "title"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "update_task"
          }
        }
      },
      "then": {
        "required": [
          "taskId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "complete_task"
          }
        }
      },
      "then": {
        "required": [
          "taskId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "delete_task"
          }
        }
      },
      "then": {
        "required": [
          "taskId"
        ]
      }
    }
  ]
}
